pipeline {
    agent any

    stages {
        
        stage('Hello') {
            
            steps {
                sh '''
                mkdir -p /dir3
                cd /dir3
                touch filetext
                cd ..

                '''
            }
        }
        stage('creating 2nd directory') {
            steps{
                sh '''
               # create another directory named dir2
               mkdir -p /dir4
                # move filetext from dir1 to dir2
                cp /dir3/filetext /dir4/

                '''

            }
        }

       
    }
}
