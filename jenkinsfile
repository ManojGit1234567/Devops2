pipeline {
    agent { label 'agent1' }

    stages {
        stage('Hello') {
            steps {
                mkdir /dir3
                cd /dir3
                touch filetext
                cd ..
            }
            steps{
               //create another directory named dir2
               mkdir /dir4
                //move filetext from dir1 to dir2
                cp /dir3/filetext /dir4/

            }
        }

       
    }
}