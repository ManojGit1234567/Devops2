pipeline {
    agent any

    stages {
        stage('Create First Directory and File') {
            steps {
                sh '''
                # Create first directory
                mkdir -p dir3
                # Create a file inside dir3
                touch dir3/filetext
                '''
            }
        }

        stage('Create Second Directory and Copy File') {
            steps {
                sh '''
                # Create second directory
                mkdir -p dir4
                # Copy file from dir3 to dir4
                cp dir3/filetext dir4/
                '''
            }
        }
    }
}